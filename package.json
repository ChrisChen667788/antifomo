{
  "name": "anti-fomo-demo",
  "version": "0.3.0+20260423",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3010",
    "build": "next build",
    "start": "next start --port 3010",
    "lint": "eslint",
    "test:backend": "cd backend && .venv311/bin/pytest -q",
    "check": "npm run lint && npm run build && npm run test:backend",
    "demo:setup": "bash scripts/setup_demo.sh",
    "demo:backend": "bash scripts/run_backend.sh",
    "demo:frontend": "bash scripts/run_frontend.sh",
    "demo:start": "bash scripts/start_demo.sh",
    "demo:stop": "bash scripts/stop_demo.sh",
    "workbuddy:doctor": "bash scripts/workbuddy_official_doctor.sh",
    "demo:smoke": "bash scripts/smoke_test.sh",
    "demo:focus-e2e": "node scripts/focus_pause_resume_e2e.mjs",
    "demo:wechat-test": "backend/.venv311/bin/python scripts/wechat_batch_test.py --file .tmp/wechat_urls.txt --min-count 30",
    "demo:simulate": "backend/.venv311/bin/python scripts/simulate_mvp_flow.py --file .tmp/wechat_urls_17.txt --report .tmp/mvp_simulation_report.md",
    "demo:plugin-validate": "backend/.venv311/bin/python scripts/plugin_batch_validate.py",
    "demo:chrome-plugin-pipeline": "node scripts/chrome_plugin_pipeline_validate.mjs",
    "collector:once": "node scripts/desktop_wechat_collector.mjs --source-file .tmp/wechat_collector_sources.txt --state-file .tmp/wechat_collector_state.json --report-file .tmp/wechat_collector_latest.md",
    "collector:start": "bash scripts/start_collector.sh",
    "collector:stop": "bash scripts/stop_collector.sh",
    "collector:status": "bash scripts/collector_status.sh",
    "collector:flush": "bash scripts/collector_flush_pending.sh 200",
    "collector:daily": "bash scripts/collector_daily_report.sh 24 12 .tmp/collector_daily_summary.md",
    "collector:sync-sources": "bash scripts/collector_import_file_sources.sh .tmp/wechat_collector_sources.txt",
    "wechat-agent:once": "backend/.venv311/bin/python scripts/wechat_pc_full_auto_agent.py --config .tmp/wechat_pc_agent_config.json --state-file .tmp/wechat_pc_agent_state.json --report-file .tmp/wechat_pc_agent_latest.json",
    "wechat-agent:start": "bash scripts/start_wechat_pc_agent.sh",
    "wechat-agent:stop": "bash scripts/stop_wechat_pc_agent.sh",
    "wechat-agent:status": "bash scripts/wechat_pc_agent_status.sh",
    "knowledge:backfill:intelligence": "backend/.venv311/bin/python scripts/backfill_knowledge_research_intelligence.py",
    "research:audit:low-quality": "backend/.venv311/bin/python scripts/audit_low_quality_research_reports.py",
    "research:rewrite:low-quality": "backend/.venv311/bin/python scripts/rewrite_low_quality_research_reports.py",
    "research:watchlists:run-due": "backend/.venv311/bin/python scripts/run_research_watchlists.py",
    "research:watchlists:automation:install": "backend/.venv311/bin/python scripts/manage_watchlist_launch_agent.py install --notify",
    "research:watchlists:automation:uninstall": "backend/.venv311/bin/python scripts/manage_watchlist_launch_agent.py uninstall",
    "research:watchlists:automation:status": "backend/.venv311/bin/python scripts/manage_watchlist_launch_agent.py status"
  },
  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "puppeteer-core": "^24.39.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
